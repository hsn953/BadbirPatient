                                    <Label Text="b. Open jars which have been previously opened?" Style="{StaticResource BodyLabel}" Margin="0" />
                                    <StackLayout RadioButtonGroup.GroupName="data7_2" RadioButtonGroup.SelectedValue="{Binding HAQDAO.Openjar}">
                                        <RadioButton Content="Without any difficulty" Value="0" />
                                        <RadioButton Content="With some difficulty" Value="1" />
                                        <RadioButton Content="With much difficulty" Value="2" />
                                        <RadioButton Content="Unable to do" Value="3" />
