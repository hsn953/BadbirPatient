                                    <StackLayout RadioButtonGroup.GroupName="data7_3" RadioButtonGroup.SelectedValue="{Binding HAQDAO.Turntap}">
                                        <RadioButton Content="Without any difficulty" Value="0" />
                                        <RadioButton Content="With some difficulty" Value="1" />
                                        <RadioButton Content="With much difficulty" Value="2" />
                                        <RadioButton Content="Unable to do" Value="3" />
                                    </StackLayout>
                                </StackLayout>
                                <Line Style="{StaticResource QuestionSpacerV}"/>                                
                            </StackLayout>
                        </Grid>
                    </xct:Expander>
                </Grid>



                <Grid Style="{StaticResource HAQGridRowB}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <BoxView  WidthRequest="5" CornerRadius="5" HorizontalOptions="Start" VerticalOptions="FillAndExpand"  BackgroundColor="{StaticResource BADBIRPurple}" Margin="0" />
                    <xct:Expander Grid.Column="1" Padding="5" VerticalOptions="StartAndExpand" >
                        <xct:Expander.Header >
                            <StackLayout Orientation="Vertical" >
                                <Label Text="Section 8"  TextColor="DarkGray" TextTransform="Uppercase"  FontSize="Small"  />
                                <Label Text="Activities" TextColor="{StaticResource BADBIRPurple}" TextTransform="Uppercase" Padding="0,0,0,15" FontSize="Medium" />
                            </StackLayout>
                        </xct:Expander.Header>
                        <Grid VerticalOptions="StartAndExpand" HorizontalOptions="FillAndExpand">
                            <StackLayout Orientation="Vertical" VerticalOptions="StartAndExpand">
                                <Label Text="Are you able to:" Style="{StaticResource BodyLabel}" FontAttributes="Bold" Margin="0" />
                                <StackLayout Orientation="Vertical">
                                    <Label Text="a. Run errands and shop?" Style="{StaticResource BodyLabel}" Margin="0"  />
                                    <StackLayout RadioButtonGroup.GroupName="data8_1" RadioButtonGroup.SelectedValue="{Binding HAQDAO.Shop}">
                                        <RadioButton Content="Without any difficulty" Value="0" />
                                        <RadioButton Content="With some difficulty" Value="1" />
                                        <RadioButton Content="With much difficulty" Value="2" />
                                        <RadioButton Content="Unable to do" Value="3" />
                                    </StackLayout>
                                </StackLayout>
                                <Line Style="{StaticResource QuestionSpacerV}"/>
                                <StackLayout Orientation="Vertical">
                                    <Label Text="b. Get in and out of a car?" Style="{StaticResource BodyLabel}" Margin="0" />
                                    <StackLayout RadioButtonGroup.GroupName="data8_2" RadioButtonGroup.SelectedValue="{Binding HAQDAO.Getincar}">
                                        <RadioButton Content="Without any difficulty" Value="0" />
                                        <RadioButton Content="With some difficulty" Value="1" />
                                        <RadioButton Content="With much difficulty" Value="2" />
                                        <RadioButton Content="Unable to do" Value="3" />
                                    </StackLayout>
                                </StackLayout>
                                <Line Style="{StaticResource QuestionSpacerV}"/>
                                <StackLayout Orientation="Vertical">
                                    <Label Text="c. Do chores such as vacuuming, housework or light gardening?" Style="{StaticResource BodyLabel}" Margin="0" />
                                    <StackLayout RadioButtonGroup.GroupName="data8_3" RadioButtonGroup.SelectedValue="{Binding HAQDAO.Housework}">
                                        <RadioButton Content="Without any difficulty" Value="0" />
                                        <RadioButton Content="With some difficulty" Value="1" />
                                        <RadioButton Content="With much difficulty" Value="2" />
                                        <RadioButton Content="Unable to do" Value="3" />
                                    </StackLayout>
                                </StackLayout>
                                <Line Style="{StaticResource QuestionSpacerV}"/>
                                <StackLayout Orientation="Vertical" >
                                    <Label Text="Please tick any AIDS or DEVICES that you usually use for any of these activities:" Style="{StaticResource BodyLabel}" Margin="0" Padding="0" />
                                    <Grid  ColumnDefinitions="Auto, Auto, *" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" VerticalOptions="Start" RowSpacing="-7" ColumnSpacing="-10">
                                        <CheckBox IsChecked="{Binding HAQDAO.Loolift}" Grid.Column="0" Grid.Row="0"/>
                                        <Label Text="Raised toilet seat (H)" Style="{StaticResource BodyLabel}" Grid.Column="1" Grid.Row="0" Grid.ColumnSpan="2" />

                                        <CheckBox IsChecked="{Binding HAQDAO.Bathseat}" Grid.Column="0" Grid.Row="1" />
