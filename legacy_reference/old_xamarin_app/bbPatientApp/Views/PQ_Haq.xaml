                                        <CheckBox IsChecked="{Binding HAQDAO.Gripping}" Grid.Column="0" Grid.Row="2" />
                                        <Label Text="Reach" Style="{StaticResource BodyLabel}" Grid.Column="1" Grid.Row="2" Grid.ColumnSpan="2"/>

                                        <CheckBox IsChecked="{Binding HAQDAO.Errands}" Grid.Column="0" Grid.Row="3" />
