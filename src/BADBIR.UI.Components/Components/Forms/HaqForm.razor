@inject IFormApiService FormService

@if (_submitted)
{
    <div class="text-center py-4">
        <div class="fs-1 mb-2">✅</div>
        <p class="fw-semibold">HAQ submitted.</p>
        <a href="/dashboard" class="btn btn-primary">Back to Dashboard</a>
    </div>
}
else
{
    <p class="mb-3">Please tick the one response which best describes your <strong>usual abilities over the past week</strong>.</p>
    <p class="text-muted small mb-4">0 = Without any difficulty &nbsp;|&nbsp; 1 = With some difficulty &nbsp;|&nbsp; 2 = With much difficulty &nbsp;|&nbsp; 3 = Unable to do</p>

    @foreach (var cat in _categories)
    {
        <div class="card mb-3 border-0 bg-light">
            <div class="card-header bg-secondary bg-opacity-10 fw-semibold">@cat.Name</div>
            <div class="card-body">
                @foreach (var q in cat.Questions)
                {
                    <div class="mb-3">
                        <p class="mb-1 fw-semibold">@q.Text</p>
                        <div class="d-flex gap-3 flex-wrap">
                            @foreach (var val in new[] {0, 1, 2, 3})
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" id="@($"{q.Key}_{val}")" name="@q.Key"
                                           checked="@(q.Value == val)" @onchange="() => q.Value = val" />
                                    <label class="form-check-label" for="@($"{q.Key}_{val}")">@val</label>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-danger">@_error</div>
    }

    <div class="d-flex gap-2 mt-3">
        <button class="btn btn-primary" disabled="@_loading" @onclick="SubmitAsync">
            @if (_loading) { <span class="spinner-border spinner-border-sm me-2"></span> }
            Submit HAQ
        </button>
        <button class="btn btn-outline-secondary" @onclick="SkipAsync">Skip</button>
    </div>
}

@code {
    private bool _loading, _submitted;
    private string? _error;

    private record HaqQ(string Key, string Text)
    {
        public int? Value { get; set; }
    }

    private record HaqCategory(string Name, HaqQ[] Questions);

    private readonly HaqCategory[] _categories =
    [
        new("Dressing and Grooming", [new("dressself","Are you able to dress yourself?"), new("shampoo","Are you able to shampoo your hair?")]),
        new("Arising",               [new("standchair","Are you able to stand up from a straight chair?"), new("bed","Are you able to get in and out of bed?")]),
        new("Eating",                [new("cutmeat","Are you able to cut your meat?"), new("liftglass","Are you able to lift a full cup or glass to your mouth?"), new("openmilk","Are you able to open a new carton of milk?")]),
        new("Walking",               [new("walkflat","Are you able to walk on flat ground?"), new("climbsteps","Are you able to climb five steps?")]),
        new("Hygiene",               [new("washdry","Are you able to wash and dry your entire body?"), new("bath","Are you able to take a bath?"), new("toilet","Are you able to get on and off the toilet?")]),
        new("Reach",                 [new("reachabove","Are you able to reach and get down a 5-pound object above your head?"), new("bend","Are you able to bend down to pick up clothing from the floor?")]),
        new("Grip",                  [new("cardoor","Are you able to open car doors?"), new("openjar","Are you able to open jars which have been previously opened?"), new("turntap","Are you able to turn taps on and off?")]),
        new("Activities",            [new("shop","Are you able to run errands and shop?"), new("getincar","Are you able to get in and out of a car?"), new("housework","Are you able to do chores such as vacuuming and light gardening?")])
    ];

    private async Task SubmitAsync()
    {
        _loading = true;
        var result = await FormService.SubmitHaqAsync(new HaqSubmitRequest
        {
            Dressself   = _categories[0].Questions[0].Value,
            Shampoo     = _categories[0].Questions[1].Value,
            Standchair  = _categories[1].Questions[0].Value,
            Bed         = _categories[1].Questions[1].Value,
            Cutmeat     = _categories[2].Questions[0].Value,
            Liftglass   = _categories[2].Questions[1].Value,
            Openmilk    = _categories[2].Questions[2].Value,
            Walkflat    = _categories[3].Questions[0].Value,
            Climbsteps  = _categories[3].Questions[1].Value,
            Washdry     = _categories[4].Questions[0].Value,
            Bath        = _categories[4].Questions[1].Value,
            Toilet      = _categories[4].Questions[2].Value,
            Reachabove  = _categories[5].Questions[0].Value,
            Bend        = _categories[5].Questions[1].Value,
            Cardoor     = _categories[6].Questions[0].Value,
            Openjar     = _categories[6].Questions[1].Value,
            Turntap     = _categories[6].Questions[2].Value,
            Shop        = _categories[7].Questions[0].Value,
            Getincar    = _categories[7].Questions[1].Value,
            Housework   = _categories[7].Questions[2].Value
        });
        _loading = false;
        if (!result.IsSuccess) { _error = result.ErrorMessage; return; }
        _submitted = true;
    }

    private async Task SkipAsync()
    {
        _loading = true;
        var result = await FormService.SubmitHaqAsync(new HaqSubmitRequest { Missingdata = true });
        _loading = false;
        if (!result.IsSuccess) { _error = result.ErrorMessage; return; }
        _submitted = true;
    }
}
