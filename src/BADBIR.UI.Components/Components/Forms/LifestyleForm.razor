@inject IFormApiService FormService

@if (_submitted)
{
    <div class="text-center py-4">
        <div class="fs-1 mb-2">✅</div>
        <p class="fw-semibold">Lifestyle form submitted.</p>
        <a href="/dashboard" class="btn btn-primary">Back to Dashboard</a>
    </div>
}
else
{
    <p class="mb-4">Please answer the following questions about your lifestyle and background.</p>

    <h6 class="text-uppercase small text-muted mb-2">Smoking</h6>
    <div class="mb-3">
        <label class="form-label fw-semibold">Have you ever smoked?</label>
        <div class="d-flex gap-3">
            <div class="form-check">
                <input class="form-check-input" type="radio" id="smkY" name="smk"
                       checked="@(_everSmoked == true)" @onchange='() => _everSmoked = true' />
                <label class="form-check-label" for="smkY">Yes</label>
            </div>
            <div class="form-check">
                <input class="form-check-input" type="radio" id="smkN" name="smk"
                       checked="@(_everSmoked == false)" @onchange='() => _everSmoked = false' />
                <label class="form-check-label" for="smkN">No</label>
            </div>
        </div>
    </div>

    <h6 class="text-uppercase small text-muted mb-2 mt-4">Alcohol</h6>
    <div class="mb-3">
        <label class="form-label fw-semibold">Do you drink alcohol?</label>
        <div class="d-flex gap-3">
            <div class="form-check">
                <input class="form-check-input" type="radio" id="alkY" name="alk"
                       checked="@(_drinksAlcohol == true)" @onchange='() => _drinksAlcohol = true' />
                <label class="form-check-label" for="alkY">Yes</label>
            </div>
            <div class="form-check">
                <input class="form-check-input" type="radio" id="alkN" name="alk"
                       checked="@(_drinksAlcohol == false)" @onchange='() => _drinksAlcohol = false' />
                <label class="form-check-label" for="alkN">No</label>
            </div>
        </div>
    </div>

    @if (_drinksAlcohol == true)
    {
        <div class="mb-3">
            <label class="form-label">Average units of alcohol per week</label>
            <input type="number" class="form-control" style="max-width:120px" @bind="_drnkunitsavg" min="0" />
        </div>
    }

    <h6 class="text-uppercase small text-muted mb-2 mt-4">Physical Measurements</h6>
    <div class="row g-3 mb-3">
        <div class="col-md-4">
            <label class="form-label">Height (cm)</label>
            <input type="number" class="form-control" @bind="_height" min="0" step="0.1" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Weight (kg)</label>
            <input type="number" class="form-control" @bind="_weight" min="0" step="0.1" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Waist (cm)</label>
            <input type="number" class="form-control" @bind="_waist" min="0" step="0.1" />
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-danger">@_error</div>
    }

    <div class="d-flex gap-2 mt-3">
        <button class="btn btn-primary" disabled="@_loading" @onclick="SubmitAsync">
            @if (_loading) { <span class="spinner-border spinner-border-sm me-2"></span> }
            Submit Lifestyle
        </button>
        <button class="btn btn-outline-secondary" @onclick="SkipAsync">Skip</button>
    </div>
}

@code {
    private bool _loading, _submitted;
    private string? _error;
    private bool? _everSmoked, _drinksAlcohol;
    private int? _drnkunitsavg;
    private float? _height, _weight, _waist;

    private async Task SubmitAsync()
    {
        _loading = true;
        var result = await FormService.SubmitLifestyleAsync(new LifestyleSubmitDto
        {
            Eversmoked   = _everSmoked,
            Drinkalcohol = _drinksAlcohol,
            Drnkunitsavg = _drinksAlcohol == true ? _drnkunitsavg : null,
            Height       = _height,
            Weight       = _weight,
            Waist        = _waist
        });
        _loading = false;
        if (!result.IsSuccess) { _error = result.ErrorMessage; return; }
        _submitted = true;
    }

    private async Task SkipAsync()
    {
        _loading = true;
        var result = await FormService.SubmitLifestyleAsync(new LifestyleSubmitDto());
        _loading = false;
        if (!result.IsSuccess) { _error = result.ErrorMessage; return; }
        _submitted = true;
    }
}
