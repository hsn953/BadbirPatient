@inject IFormApiService FormService
@inject NavigationManager Nav

@if (_submitted)
{
    <div class="text-center py-4">
        <div class="fs-1 mb-2">✅</div>
        <p class="fw-semibold">PGA submitted.</p>
        <a href="/dashboard" class="btn btn-primary">Back to Dashboard</a>
    </div>
}
else
{
    <p class="mb-4">How would you describe the overall severity of your psoriasis <strong>today</strong>?</p>

    <div class="d-flex flex-column gap-2 mb-4">
        @foreach (var (score, label) in _options)
        {
            <div class="form-check p-3 border rounded @(_selected == score ? "border-primary bg-primary bg-opacity-10" : "")">
                <input class="form-check-input" type="radio" id="pga@score" name="pga"
                       checked="@(_selected == score)"
                       @onchange="() => _selected = score" />
                <label class="form-check-label" for="pga@score">@score — @label</label>
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-danger">@_error</div>
    }

    <div class="d-flex gap-2">
        <button class="btn btn-primary" disabled="@(_loading || _selected is null)" @onclick="SubmitAsync">
            @if (_loading) { <span class="spinner-border spinner-border-sm me-2"></span> }
            Submit
        </button>
        <button class="btn btn-outline-secondary" @onclick="SkipAsync">Skip this form</button>
    </div>
}

@code {
    private static readonly (int Score, string Label)[] _options =
    [
        (1, "Clear — no psoriasis"),
        (2, "Almost clear — barely noticeable"),
        (3, "Mild — slight but definite involvement"),
        (4, "Moderate — moderate involvement"),
        (5, "Severe — very marked involvement")
    ];

    private int? _selected;
    private bool _loading;
    private bool _submitted;
    private string? _error;

    private async Task SubmitAsync()
    {
        if (_selected is null) return;
        _loading = true;
        var result = await FormService.SubmitPgaAsync(new PgaSubmitDto { Pgascore = _selected, SkipForm = false });
        _loading = false;
        if (!result.IsSuccess) { _error = result.ErrorMessage; return; }
        _submitted = true;
    }

    private async Task SkipAsync()
    {
        _loading = true;
        var result = await FormService.SubmitPgaAsync(new PgaSubmitDto { SkipForm = true });
        _loading = false;
        if (!result.IsSuccess) { _error = result.ErrorMessage; return; }
        _submitted = true;
    }
}
