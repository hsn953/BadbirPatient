@* Displays a simple password strength bar and checklist *@

<div class="mt-2">
    <div class="progress mb-1" style="height:6px" aria-hidden="true">
        <div class="progress-bar @BarClass" style="width: @(Strength * 25)%"></div>
    </div>
    <div class="row gx-2 text-muted" style="font-size:0.78rem">
        <div class="col-auto @Check(HasLength)">@Tick(HasLength) 8+ chars</div>
        <div class="col-auto @Check(HasUpper)">@Tick(HasUpper) UPPER</div>
        <div class="col-auto @Check(HasLower)">@Tick(HasLower) lower</div>
        <div class="col-auto @Check(HasDigit)">@Tick(HasDigit) 123</div>
        <div class="col-auto @Check(HasSymbol)">@Tick(HasSymbol) !@@#</div>
    </div>
</div>

@code {
    [Parameter] public string Password { get; set; } = string.Empty;

    private bool HasLength => Password.Length >= 8;
    private bool HasUpper  => Password.Any(char.IsUpper);
    private bool HasLower  => Password.Any(char.IsLower);
    private bool HasDigit  => Password.Any(char.IsDigit);
    private bool HasSymbol => Password.Any(c => !char.IsLetterOrDigit(c));

    private int Strength => (HasLength ? 1 : 0) + (HasUpper ? 1 : 0) +
                            (HasLower ? 1 : 0) + (HasDigit ? 1 : 0) +
                            (HasSymbol ? 1 : 0);

    private string BarClass => Strength switch
    {
        0 or 1 => "bg-danger",
        2 or 3 => "bg-warning",
        4      => "bg-info",
        _      => "bg-success"
    };

    private static string Check(bool ok) => ok ? "text-success" : "";
    private static string Tick(bool ok)  => ok ? "✓" : "✗";
}
