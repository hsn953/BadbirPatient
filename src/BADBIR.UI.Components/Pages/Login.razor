@page "/login"
@inject IAuthApiService AuthService
@inject BabdirAuthStateProvider AuthProvider
@inject NavigationManager Nav

<PageTitle>Log In – BADBIR Patient</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h2 class="card-title mb-1 text-center">Log In</h2>
                    <p class="text-muted text-center small mb-4">Enter your email and password to continue</p>

                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="alert alert-danger" role="alert">@_errorMessage</div>
                    }

                    <EditForm Model="_model" OnValidSubmit="HandleLoginAsync" FormName="login">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label for="email" class="form-label">Email address</label>
                            <InputText id="email" class="form-control" @bind-Value="_model.Email"
                                       autocomplete="email" placeholder="your@email.com" />
                            <ValidationMessage For="() => _model.Email" />
                        </div>

                        <div class="mb-3">
                            <label for="password" class="form-label">Password</label>
                            <div class="input-group">
                                <InputText id="password" class="form-control"
                                           @bind-Value="_model.Password"
                                           type="@(_showPassword ? "text" : "password")"
                                           autocomplete="current-password" />
                                <button type="button" class="btn btn-outline-secondary"
                                        @onclick="() => _showPassword = !_showPassword"
                                        aria-label="Toggle password visibility">
                                    @(_showPassword ? "🙈" : "👁️")
                                </button>
                            </div>
                            <ValidationMessage For="() => _model.Password" />
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <a href="/account-recovery" class="small text-decoration-none">Forgot password?</a>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 mb-3" disabled="@_loading">
                            @if (_loading) { <span class="spinner-border spinner-border-sm me-2"></span> }
                            Log In
                        </button>

                        <p class="text-center small mb-0">
                            Don't have an account? <a href="/register">Register here</a>
                        </p>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    private readonly LoginRequestDto _model = new();
    private string? _errorMessage;
    private bool _loading;
    private bool _showPassword;

    private async Task HandleLoginAsync()
    {
        _loading      = true;
        _errorMessage = null;

        var result = await AuthService.LoginAsync(_model);
        _loading = false;

        if (!result.IsSuccess || result.Data is null)
        {
            _errorMessage = result.ErrorMessage ?? "Login failed. Please try again.";
            return;
        }

        await AuthProvider.NotifyLoginAsync(result.Data);

        // Route based on account state
        var dto = result.Data;
        if (!dto.ConsentGiven)
        {
            Nav.NavigateTo("/consent");
            return;
        }
        if (dto.SelfReportedDiagnosis is null)
        {
            Nav.NavigateTo("/diagnosis");
            return;
        }

        var returnUrl = ReturnUrl;
        Nav.NavigateTo(!string.IsNullOrWhiteSpace(returnUrl)
            ? Uri.UnescapeDataString(returnUrl)
            : "/dashboard");
    }
}
