@page "/diagnosis"
@attribute [Authorize]
@inject IPatientApiService PatientService
@inject NavigationManager Nav

<PageTitle>Diagnosis Information – BADBIR Patient</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">

                    @if (_submitted)
                    {
                        <div class="text-center py-4">
                            <div class="fs-1 mb-3">✅</div>
                            <h3>Thank you</h3>
                            <p class="text-muted">Your answer has been saved. You can now proceed to your dashboard and start completing your forms.</p>
                            <a href="/dashboard" class="btn btn-primary mt-2">Go to Dashboard →</a>
                        </div>
                    }
                    else
                    {
                        <h3>About Your Diagnosis</h3>
                        <p class="text-muted mb-4">
                            One of the questionnaires (HAQ) is only relevant if you have been diagnosed with
                            inflammatory arthritis. Your clinical team will confirm your diagnosis, but we
                            need your answer to set up your forms correctly.
                        </p>

                        <p class="fw-semibold fs-5">
                            Has a rheumatologist confirmed you have an inflammatory arthritis (including psoriatic arthritis)?
                        </p>

                        <div class="d-flex flex-column gap-3 mt-3 mb-4">
                            <div class="form-check p-3 border rounded @(_selected == SelfReportedDiagnosis.Yes ? "border-primary bg-primary bg-opacity-10" : "")">
                                <input class="form-check-input" type="radio" id="dxYes" name="diagnosis"
                                       checked="@(_selected == SelfReportedDiagnosis.Yes)"
                                       @onchange='() => _selected = SelfReportedDiagnosis.Yes' />
                                <label class="form-check-label fw-semibold" for="dxYes">
                                    ✅ Yes — I have a rheumatologist diagnosis of inflammatory arthritis or psoriatic arthritis
                                </label>
                            </div>
                            <div class="form-check p-3 border rounded @(_selected == SelfReportedDiagnosis.No ? "border-primary bg-primary bg-opacity-10" : "")">
                                <input class="form-check-input" type="radio" id="dxNo" name="diagnosis"
                                       checked="@(_selected == SelfReportedDiagnosis.No)"
                                       @onchange='() => _selected = SelfReportedDiagnosis.No' />
                                <label class="form-check-label fw-semibold" for="dxNo">
                                    ❌ No — I do not have such a diagnosis
                                </label>
                            </div>
                            <div class="form-check p-3 border rounded @(_selected == SelfReportedDiagnosis.NotSure ? "border-primary bg-primary bg-opacity-10" : "")">
                                <input class="form-check-input" type="radio" id="dxNotSure" name="diagnosis"
                                       checked="@(_selected == SelfReportedDiagnosis.NotSure)"
                                       @onchange='() => _selected = SelfReportedDiagnosis.NotSure' />
                                <label class="form-check-label fw-semibold" for="dxNotSure">
                                    🤔 Not sure — I'm not certain of my diagnosis
                                </label>
                            </div>
                        </div>

                        <p class="text-muted small">
                            <strong>Note:</strong> Your clinical team will confirm your diagnosis. If you answer "Yes" or "Not sure",
                            the HAQ (Health Assessment Questionnaire) will be included in your forms. Your clinician may adjust this.
                        </p>

                        @if (!string.IsNullOrEmpty(_error))
                        {
                            <div class="alert alert-danger">@_error</div>
                        }

                        <button class="btn btn-primary mt-2" disabled="@(_loading || _selected is null)" @onclick="SaveAsync">
                            @if (_loading) { <span class="spinner-border spinner-border-sm me-2"></span> }
                            Save &amp; Continue →
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private SelfReportedDiagnosis? _selected;
    private bool _loading;
    private bool _submitted;
    private string? _error;

    private async Task SaveAsync()
    {
        if (_selected is null) { _error = "Please select an answer."; return; }

        _loading = true;
        var result = await PatientService.UpdateDiagnosisAsync(new DiagnosisUpdateDto
        {
            SelfReportedDiagnosis = _selected.Value
        });
        _loading = false;

        if (!result.IsSuccess) { _error = result.ErrorMessage; return; }
        _submitted = true;
    }
}
