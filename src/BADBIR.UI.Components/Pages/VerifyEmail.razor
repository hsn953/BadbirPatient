@page "/verify-email"
@inject IAuthApiService AuthService
@inject NavigationManager Nav

<PageTitle>Email Verification – BADBIR Patient</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            @if (_verifying)
            {
                <div class="spinner-border text-primary mb-3"></div>
                <p>Verifying your email address…</p>
            }
            else if (_success)
            {
                <div class="fs-1 mb-3">✅</div>
                <h3>Email Verified!</h3>
                <p class="text-muted">Your email address has been verified. You can now log in.</p>
                <a href="/login" class="btn btn-primary mt-2">Log In</a>
            }
            else
            {
                <div class="fs-1 mb-3">❌</div>
                <h3>Verification Failed</h3>
                <p class="text-muted">@_error</p>
                <div class="mt-3">
                    <button class="btn btn-outline-primary me-2" @onclick="ResendAsync">Resend Verification Email</button>
                    <a href="/login" class="btn btn-outline-secondary">Return to Login</a>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? UserId { get; set; }
    [SupplyParameterFromQuery] public string? Token { get; set; }
    [SupplyParameterFromQuery] public string? Email { get; set; }

    private bool _verifying = true;
    private bool _success;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(UserId) || string.IsNullOrWhiteSpace(Token))
        {
            _verifying = false;
            _error     = "This verification link appears to be invalid. Please request a new one.";
            return;
        }

        // Use the typed AuthApiService so the base URL comes from configuration.
        var result = await AuthService.VerifyEmailAsync(UserId, Token);
        _success   = result.IsSuccess;
        if (!_success)
            _error = result.ErrorMessage ?? "The verification link may have expired or already been used.";
        _verifying = false;
    }

    private async Task ResendAsync()
    {
        if (!string.IsNullOrWhiteSpace(Email))
            await AuthService.SendVerificationEmailAsync(Email);
        _error = "A new verification email has been sent if that address is registered.";
    }
}
