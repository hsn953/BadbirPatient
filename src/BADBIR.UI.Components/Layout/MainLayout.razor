@inherits LayoutComponentBase
@inject BabdirAuthStateProvider AuthProvider
@inject NavigationManager Nav

<div class="page">
    <header class="badbir-topnav navbar navbar-expand-lg navbar-dark bg-primary py-2 px-4">
        <a class="navbar-brand fw-bold" href="/">
            <span class="me-2">🩺</span>BADBIR Patient
        </a>
        <div class="ms-auto d-flex align-items-center gap-3">
            <AuthorizeView>
                <Authorized>
                    <a href="/account" class="text-white text-decoration-none small">
                        <span class="me-1">👤</span>@context.User.Identity?.Name
                    </a>
                    <button class="btn btn-outline-light btn-sm" @onclick="LogoutAsync">Log out</button>
                </Authorized>
                <NotAuthorized>
                    <a href="/login" class="btn btn-outline-light btn-sm me-2">Log in</a>
                    <a href="/register" class="btn btn-light btn-sm">Register</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </header>

    <div class="d-flex flex-fill">
        <AuthorizeView>
            <Authorized>
                <nav class="badbir-sidebar d-none d-md-flex flex-column p-3 bg-light border-end" style="width:220px;min-height:calc(100vh - 56px)">
                    <ul class="nav flex-column gap-1">
                        <li class="nav-item">
                            <NavLink class="nav-link rounded" href="/dashboard" Match="NavLinkMatch.All">
                                📊 Dashboard
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link rounded" href="/consent">
                                ✅ Consent
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link rounded" href="/forms">
                                📋 My Forms
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link rounded" href="/account">
                                ⚙️ Account
                            </NavLink>
                        </li>
                    </ul>
                </nav>
            </Authorized>
        </AuthorizeView>

        <main class="flex-fill p-4">
            <HoldingBanner />
            <ErrorBoundary>
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent Context="ex">
                    <div class="alert alert-danger" role="alert">
                        <strong>An unexpected error occurred.</strong>
                        <a href="/" class="ms-2">Return to home</a>
                    </div>
                </ErrorContent>
            </ErrorBoundary>
        </main>
    </div>
</div>

@code {
    private async Task LogoutAsync()
    {
        await AuthProvider.NotifyLogoutAsync();
        Nav.NavigateTo("/login");
    }
}
